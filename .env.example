DATABASE_URL=postgresql://prism:prism@localhost:5433/prism_club?schema=public
DATABASE_URL_TEST=postgresql://prism:prism@localhost:5433/prism_club_test?schema=public

API_PORT=3000
NODE_ENV=development

# M13: JWT signing secret. MUST be overridden in non-dev environments.
JWT_SECRET=prism-club-dev-secret-do-not-use-in-prod

# M13: allow the dev-only X-User-Id header. Defaults to true when
# NODE_ENV != production. Set to 1 in test/CI to be explicit.
ALLOW_X_USER_ID=1
