# ============================================================================
# PRISM Club — example environment variables.
# Copy to `.env` and adjust per environment.
# ============================================================================

# --- Database (required) ---
# Local dev: points at the docker-compose Postgres on host port 5433.
DATABASE_URL=postgresql://prism:prism@localhost:5433/prism_club?schema=public
# Used by the e2e test suite. Same Postgres, separate database.
DATABASE_URL_TEST=postgresql://prism:prism@localhost:5433/prism_club_test?schema=public

# --- API process ---
API_PORT=3000
# development | test | production. Some guards (X-User-Id fallback, CORS
# default) loosen when NODE_ENV != production.
NODE_ENV=development

# --- M13: auth ---
# JWT signing secret. MUST be a long random value in production. Rotating
# this invalidates every issued token.
JWT_SECRET=prism-club-dev-secret-do-not-use-in-prod
# When set to 1 (or NODE_ENV != production), the AuthGuard also accepts the
# legacy X-User-Id header used by tests and scripts/smoke.sh.
ALLOW_X_USER_ID=1

# --- M14: deployment / runtime ---
# Comma-separated allowed origins for browser clients. Empty or `*` allows
# anything (dev default). Production MUST set this explicitly, e.g.:
#   CORS_ORIGINS=https://club.prism.app,https://admin.prism.app
CORS_ORIGINS=*

# Where uploaded media files land. Local dev defaults to ./uploads.
# In container deployments, point this at a mounted volume or object store.
UPLOADS_DIR=uploads

# --- M15: PRISM EVENT / CONTENIDO integration ---
# Which IEventsClient to bind:
#   mock  — bundled JSON fixture (default; safe for dev/test/demo).
#   prism — real HTTP client. Requires PRISM_EVENTS_API_BASE_URL to be set;
#           otherwise the module logs a warning and falls back to mock.
EVENTS_CLIENT_MODE=mock
# Base URL of the real PRISM EVENT / CONTENIDO API (no trailing slash).
# Example: https://events.prism.app/api/v1
PRISM_EVENTS_API_BASE_URL=
# Optional Bearer token forwarded as Authorization to the events service.
PRISM_EVENTS_API_KEY=
# Per-request timeout in milliseconds. Failures (timeout, 5xx, network)
# degrade gracefully: search returns [], getById returns null.
PRISM_EVENTS_TIMEOUT_MS=4000
