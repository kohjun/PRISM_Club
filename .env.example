# ============================================================================
# PRISM Club — example environment variables.
# Copy to `.env` and adjust per environment.
# ============================================================================

# --- Database (required) ---
# Local dev: points at the docker-compose Postgres on host port 5433.
DATABASE_URL=postgresql://prism:prism@localhost:5433/prism_club?schema=public
# Used by the e2e test suite. Same Postgres, separate database.
DATABASE_URL_TEST=postgresql://prism:prism@localhost:5433/prism_club_test?schema=public

# --- API process ---
API_PORT=3000
# development | test | production. Some guards (X-User-Id fallback, CORS
# default) loosen when NODE_ENV != production.
NODE_ENV=development

# --- Build metadata (M21) ---
# All four are SAFE to expose via GET /v1/health/version. Defaults to
# 'unknown' / null if unset.
# Populate at container build time (e.g. via --build-arg + Dockerfile
# ENV, or via the deploy platform's "set env on roll-out" hook).
APP_VERSION=
GIT_SHA=
BUILD_TIME=
# local | staging | beta | production. Anything else → 'unknown'.
RELEASE_CHANNEL=local

# --- M13: auth ---
# JWT signing secret. MUST be a long random value in production. Rotating
# this invalidates every issued token.
JWT_SECRET=prism-club-dev-secret-do-not-use-in-prod
# When set to 1 (or NODE_ENV != production), the AuthGuard also accepts the
# legacy X-User-Id header used by tests and scripts/smoke.sh.
ALLOW_X_USER_ID=1
# scripts/smoke.sh auth mode (consumed by the script itself, not the API):
#   legacy → X-User-Id header on every request (requires ALLOW_X_USER_ID=1).
#   jwt    → POST /v1/auth/login per persona, then Authorization: Bearer …
# Defaults to legacy if unset. See docs/STAGING_SMOKE.md.
SMOKE_AUTH_MODE=legacy

# --- M14: deployment / runtime ---
# Comma-separated allowed origins for browser clients. Empty or `*` allows
# anything (dev default). Production MUST set this explicitly, e.g.:
#   CORS_ORIGINS=https://club.prism.app,https://admin.prism.app
CORS_ORIGINS=*

# Where uploaded media files land. Local dev defaults to ./uploads.
# In container deployments, point this at a mounted volume or object store.
UPLOADS_DIR=uploads

# --- M15: PRISM EVENT / CONTENIDO integration ---
# Which IEventsClient to bind:
#   mock  — bundled JSON fixture (default; safe for dev/test/demo).
#   prism — real HTTP client. Requires PRISM_EVENTS_API_BASE_URL to be set;
#           otherwise the module logs a warning and falls back to mock.
EVENTS_CLIENT_MODE=mock
# Base URL of the real PRISM EVENT / CONTENIDO API (no trailing slash).
# Example: https://events.prism.app/api/v1
PRISM_EVENTS_API_BASE_URL=
# Optional Bearer token forwarded as Authorization to the events service.
PRISM_EVENTS_API_KEY=
# Per-request timeout in milliseconds. Failures (timeout, 5xx, network)
# degrade gracefully: search returns [], getById returns null.
PRISM_EVENTS_TIMEOUT_MS=4000

# --- M16: media storage ---
# local — writes to UPLOADS_DIR (set above); served via /uploads/* by the API.
# s3    — writes to an S3-compatible bucket; requires the S3_* vars below
#         AND MEDIA_PUBLIC_BASE_URL (the public URL prefix that browser
#         clients can fetch from).
MEDIA_STORAGE_MODE=local

# Public URL prefix prepended to object keys when MEDIA_STORAGE_MODE=s3.
# Example: https://cdn.club.prism.app
MEDIA_PUBLIC_BASE_URL=

# S3-compatible target (AWS S3, Cloudflare R2, MinIO, ...).
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: override endpoint for non-AWS hosts (e.g. R2 / MinIO).
S3_ENDPOINT=
# Optional: object key prefix; defaults to "uploads".
S3_OBJECT_PREFIX=uploads
# Optional: force path-style addressing (1/true). MinIO often needs this.
S3_FORCE_PATH_STYLE=

# --- M17: notification delivery ---
# noop  — in-app notifications only (default, dev/test/smoke).
# email — also dispatch via the email boundary. Bundled provider is inert
#         until a real provider lands.
# push  — also dispatch via the push boundary (FCM/APNS — stubbed today).
NOTIFICATION_DELIVERY_MODE=noop

# Email provider (M17 boundary, not yet wired to a real ESP):
EMAIL_PROVIDER=
EMAIL_FROM_ADDRESS=
EMAIL_API_KEY=
EMAIL_REGION=

# Push provider (M17 boundary, not yet wired to FCM/APNS):
PUSH_PROVIDER=
PUSH_SERVICE_ACCOUNT=
