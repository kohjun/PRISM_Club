// PRISM Club schema — milestones 1 + 2.
// See docs/03_ARCHITECTURE_AND_DATA.md §5 for the full ERD this is a subset of.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

model User {
  id              String    @id @default(uuid()) @db.Uuid
  status          String    @default("ACTIVE")
  // Identity & credentials (M-P1.1). Existing seed personas are backfilled to
  // oauth_provider='DEV'; passwordless dev login keeps working when
  // ALLOW_DEV_LOGIN=1. Email uses citext (case-insensitive). Composite uniqueness
  // on (oauth_provider, oauth_id) is enforced via a partial index in the migration
  // — Prisma's @@unique cannot express WHERE clauses.
  email           String?   @unique @db.Citext
  phone           String?
  passwordHash    String?   @map("password_hash")
  oauthProvider   String?   @map("oauth_provider") // KAKAO | EMAIL | DEV
  oauthId         String?   @map("oauth_id")
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  profile                 Profile?
  roles                   UserRole[]
  rooms                   Room[]
  posts                   Post[]
  replies                 Reply[]
  reactions               Reaction[]
  references              Reference[]
  contributions           KnowledgeContribution[]  @relation("Contributor")
  resolvedContributions   KnowledgeContribution[]  @relation("Resolver")
  follows                 RoomFollow[]
  savedItems              SavedItem[]
  notifications           Notification[]
  following               UserFollow[]             @relation("UserFollowing")
  followers               UserFollow[]             @relation("UserFollowers")
  reports                 Report[]                 @relation("ReportReporter")
  resolvedReports         Report[]                 @relation("ReportResolver")
  moderationActions       ModerationAction[]
  mediaAssets             MediaAsset[]
  refreshTokens           RefreshToken[]
  deviceTokens            DeviceToken[]
  notificationPreference  NotificationPreference?
  knowledgeRevisions      KnowledgeBlockRevision[]
  contributionReputation  ContributionReputation?
  referenceSourceRules    ReferenceSourceRule[]
  eventRsvps              EventRsvp[]
  recruitmentApplications RecruitmentApplication[]
  eventReminderSends      EventReminderSend[]
  eventReviews            EventReview[]
  savedCollections        SavedCollection[]
  followRecommendations   FollowRecommendation[]   @relation("FollowRecOwner")
  recommendedByOthers     FollowRecommendation[]   @relation("FollowRecCandidate")
  mentions                Mention[]                @relation("MentionedUser")
  authoredMentions        Mention[]                @relation("MentionActor")
  blocking                UserBlock[]              @relation("Blocker")
  blockedBy               UserBlock[]              @relation("Blocked")
  muting                  UserMute[]               @relation("Muter")
  mutedBy                 UserMute[]               @relation("Muted")
  pollVotes               PollVote[]
  boosts                  PostBoost[]
  eventLivePosts          EventLivePost[]
  roomRolesHeld           RoomRole[]               @relation("RoomRoleMember")
  roomRolesGranted        RoomRole[]               @relation("RoomRoleGranter")

  @@map("users")
}

// Opaque refresh tokens. Rotation lineage is tracked via family_id so a reused
// (revoked) child token can invalidate the entire family (replay defense).
// token_hash is SHA-256(rawToken); the raw token is never persisted.
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  familyId  String    @map("family_id") @db.Uuid
  userAgent String?   @map("user_agent")
  ip        String?
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([familyId])
  @@map("refresh_tokens")
}

// Short-lived OAuth state for Kakao authorization flow. Holds the CSRF state,
// PKCE code_verifier, and nonce. Rows expire 10 minutes after creation; the
// service filters by expires_at and a periodic cleanup is optional.
model OAuthState {
  state        String   @id
  codeVerifier String   @map("code_verifier")
  nonce        String
  redirectTo   String?  @map("redirect_to")
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([expiresAt])
  @@map("oauth_states")
}

model Report {
  id                  String    @id @default(uuid()) @db.Uuid
  reporterId          String    @map("reporter_id") @db.Uuid
  targetType          String    @map("target_type")
  targetId            String    @map("target_id") @db.Uuid
  reason              String
  details             String?
  status              String    @default("OPEN")
  resolution          String?
  resolvedBy          String?   @map("resolved_by") @db.Uuid
  resolvedAt          DateTime? @map("resolved_at") @db.Timestamptz(6)
  resolverNote        String?   @map("resolver_note")
  // P5.2 auto-dismiss reason. Non-null means a rule short-circuited
  // the report instead of opening it for human review (e.g. report
  // flood from this reporter).
  autoDismissedReason String?   @map("auto_dismissed_reason")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  reporter User  @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver User? @relation("ReportResolver", fields: [resolvedBy], references: [id])

  @@index([status, createdAt(sort: Desc)])
  @@index([reporterId, createdAt(sort: Desc)])
  @@map("reports")
}

model ModerationAction {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String   @map("actor_id") @db.Uuid
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id") @db.Uuid
  reportId   String?  @map("report_id") @db.Uuid
  note       String?
  // P5.3: bulk-resolve batch identifier. All ModerationAction rows
  // produced by a single bulk operation share the same batch_id so
  // the audit log can group them.
  batchId    String?  @map("batch_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User @relation(fields: [actorId], references: [id])

  @@index([targetType, targetId, createdAt(sort: Desc)])
  @@index([batchId])
  @@map("moderation_actions")
}

// P5.2 auto-moderation rule catalog.
//
// `kind` is the rule type the service knows how to evaluate:
//   - DUPLICATE_POST_HASH: hides a NEW/MEMBER's post that matches
//     a normalized-body hash of their own posts in the last 24h.
//   - REPORT_FLOOD: auto-dismisses reports from a user who already
//     submitted N within the last hour.
//   - RAPID_FIRE_POSTS: future — caps posts/minute from same user.
// `params` jsonb carries rule-specific thresholds so admins can
// tune without a schema migration.
model AutoModerationRule {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  kind      String
  params    Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([kind])
  @@map("auto_moderation_rules")
}

model AnalyticsEvent {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  eventType String   @map("event_type")
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([eventType, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@map("analytics_events")
}

model UserFollow {
  id         String   @id @default(uuid()) @db.Uuid
  followerId String   @map("follower_id") @db.Uuid
  followedId String   @map("followed_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  follower User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  followed User @relation("UserFollowers", fields: [followedId], references: [id], onDelete: Cascade)

  @@unique([followerId, followedId])
  @@index([followedId])
  @@map("user_follows")
}

model Profile {
  userId    String   @id @map("user_id") @db.Uuid
  nickname  String   @unique
  avatarUrl String?  @map("avatar_url")
  bio       String?
  region    String?
  interests Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// Empty in milestone 1 seed; default MEMBER is implicit when no row.
// Future values: MEMBER, VERIFIED_PLANNER, MODERATOR, ADMIN, CURATOR.
model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String
  source    String?
  grantedAt DateTime @default(now()) @map("granted_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

// ---------------------------------------------------------------------------
// Community structure
// ---------------------------------------------------------------------------

model Space {
  id           String @id @default(uuid()) @db.Uuid
  slug         String @unique
  name         String
  audience     String @default("PARTICIPANT") // PARTICIPANT | PLANNER
  accessPolicy String @default("PUBLIC") @map("access_policy") // PUBLIC | PLANNER_ONLY (not enforced yet)
  status       String @default("ACTIVE")

  categories Category[]

  @@map("spaces")
}

model Category {
  id          String  @id @default(uuid()) @db.Uuid
  spaceId     String  @map("space_id") @db.Uuid
  slug        String  @unique
  name        String
  description String?
  sortOrder   Int     @default(0) @map("sort_order")
  status      String  @default("ACTIVE")

  space    Space     @relation(fields: [spaceId], references: [id])
  topicHub TopicHub?
  rooms    Room[]

  @@map("categories")
}

// ---------------------------------------------------------------------------
// Knowledge layer
// ---------------------------------------------------------------------------

model TopicHub {
  id         String   @id @default(uuid()) @db.Uuid
  categoryId String   @unique @map("category_id") @db.Uuid
  title      String
  summary    String
  status     String   @default("PUBLISHED")
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  category      Category                @relation(fields: [categoryId], references: [id])
  blocks        KnowledgeBlock[]
  signals       TopicSignal[]
  eventLinks    TopicHubEventLink[]
  refLinks      TopicHubReferenceLink[]
  contributions KnowledgeContribution[]
  digests       TopicHubDigest[]
  similarFrom   TopicHubSimilarity[]    @relation("TopicHubSimilarityHub")
  similarTo     TopicHubSimilarity[]    @relation("TopicHubSimilaritySimilar")

  @@map("topic_hubs")
}

// P7.1 persisted hub→hub similarity scores. One row per
// (topicHubId, similarHubId) directed edge — the cron persists both
// (A→B) and (B→A) so the GET endpoint can look up either side in O(log
// N). `score` ∈ (0, 1]; rows with score < threshold are not persisted.
// `reason` jsonb shape (schemaVersion=1):
//   {
//     schemaVersion: 1,
//     shared_contributor_count: int,
//     shared_room_count: int
//   }
model TopicHubSimilarity {
  id           String   @id @default(uuid()) @db.Uuid
  topicHubId   String   @map("topic_hub_id") @db.Uuid
  similarHubId String   @map("similar_hub_id") @db.Uuid
  score        Float    @db.DoublePrecision
  reason       Json
  computedAt   DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)

  hub        TopicHub @relation("TopicHubSimilarityHub", fields: [topicHubId], references: [id], onDelete: Cascade)
  similarHub TopicHub @relation("TopicHubSimilaritySimilar", fields: [similarHubId], references: [id], onDelete: Cascade)

  @@unique([topicHubId, similarHubId])
  @@index([topicHubId, score(sort: Desc)])
  @@map("topic_hub_similarity")
}

// Block types: OVERVIEW | POPULAR_FORMAT | RECOMMENDED_PARTY_SIZE | MOOD_TIPS |
//              FAQ | CHECKLIST | WARNING
model KnowledgeBlock {
  id         String   @id @default(uuid()) @db.Uuid
  topicHubId String   @map("topic_hub_id") @db.Uuid
  blockType  String   @map("block_type")
  title      String
  body       String
  sortOrder  Int      @default(0) @map("sort_order")
  status     String   @default("PUBLISHED")
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  hub           TopicHub                 @relation(fields: [topicHubId], references: [id], onDelete: Cascade)
  contributions KnowledgeContribution[]
  revisions     KnowledgeBlockRevision[]

  @@map("knowledge_blocks")
}

// Full audit timeline for a knowledge block (P2.1). One row per
// material change. `source`:
//   - SEED         backfilled at migration time for blocks that
//                  already existed (or for blocks created via seed.ts
//                  during local dev).
//   - CONTRIBUTION emitted by knowledge-contribution.service when a
//                  curator approves; `contribution_id` points to the
//                  approving contribution row.
//   - ADMIN        operator-level edits done outside the contribution
//                  flow (admin tooling, hot-fix scripts).
// `version` is monotonic per `block_id`, enforced by the unique
// constraint. `changed_by_id` is nullable so SEED rows from missing
// authors and rows from deleted users (ON DELETE SET NULL) still
// preserve the history.
model KnowledgeBlockRevision {
  id             String   @id @default(uuid()) @db.Uuid
  blockId        String   @map("block_id") @db.Uuid
  version        Int
  blockType      String   @map("block_type")
  title          String
  body           String
  changedById    String?  @map("changed_by_id") @db.Uuid
  changedAt      DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)
  contributionId String?  @map("contribution_id") @db.Uuid
  source         String // SEED | CONTRIBUTION | ADMIN

  block        KnowledgeBlock         @relation(fields: [blockId], references: [id], onDelete: Cascade)
  changedBy    User?                  @relation(fields: [changedById], references: [id], onDelete: SetNull)
  contribution KnowledgeContribution? @relation(fields: [contributionId], references: [id], onDelete: SetNull)

  @@unique([blockId, version])
  @@index([blockId, changedAt(sort: Desc)])
  @@index([changedById, changedAt(sort: Desc)])
  @@map("knowledge_block_revisions")
}

// Aggregate reputation per contributor (P2.2). Lazily updated inside
// the same transaction that resolves the contribution row, so the
// counter stays in lockstep with the contribution table.
//
// weighted_score formula (floored at 0):
//   approved*3 - rejected*1 - needs_changes*0.5 - withdrawn*0.2
//
// Self-approve is blocked at the service layer; this prevents a
// curator from inflating their own score by approving their own work.
model ContributionReputation {
  userId            String    @id @map("user_id") @db.Uuid
  approvedCount     Int       @default(0) @map("approved_count")
  rejectedCount     Int       @default(0) @map("rejected_count")
  needsChangesCount Int       @default(0) @map("needs_changes_count")
  withdrawnCount    Int       @default(0) @map("withdrawn_count")
  weightedScore     Decimal   @default(0) @map("weighted_score") @db.Decimal(10, 2)
  lastResolvedAt    DateTime? @map("last_resolved_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([weightedScore(sort: Desc)])
  @@map("contribution_reputation")
}

// Static in milestone 1 — populated by seed, not recomputed.
// Signal types: POPULAR_REFERENCE_COUNT | HOT_DEBATE_TITLE | VERIFIED_REVIEW_COUNT
model TopicSignal {
  id           String   @id @default(uuid()) @db.Uuid
  topicHubId   String   @map("topic_hub_id") @db.Uuid
  signalType   String   @map("signal_type")
  title        String
  payload      Json
  calculatedAt DateTime @default(now()) @map("calculated_at") @db.Timestamptz(6)

  hub TopicHub @relation(fields: [topicHubId], references: [id], onDelete: Cascade)

  @@map("topic_signals")
}

// Hub-level "related events" — independent of any single knowledge block.
model TopicHubEventLink {
  topicHubId  String @map("topic_hub_id") @db.Uuid
  eventCardId String @map("event_card_id") @db.Uuid
  sortOrder   Int    @default(0) @map("sort_order")

  hub       TopicHub  @relation(fields: [topicHubId], references: [id], onDelete: Cascade)
  eventCard EventCard @relation(fields: [eventCardId], references: [id], onDelete: Cascade)

  @@id([topicHubId, eventCardId])
  @@map("topic_hub_event_links")
}

// Hub-level "popular references" — independent of any single knowledge block.
model TopicHubReferenceLink {
  topicHubId  String @map("topic_hub_id") @db.Uuid
  referenceId String @map("reference_id") @db.Uuid
  sortOrder   Int    @default(0) @map("sort_order")

  hub       TopicHub  @relation(fields: [topicHubId], references: [id], onDelete: Cascade)
  reference Reference @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@id([topicHubId, referenceId])
  @@map("topic_hub_reference_links")
}

// Weekly "what changed in this hub" rollup (P2.4). One row per hub
// per ISO-week starting Mon 00:00 Asia/Seoul. Empty weeks intentionally
// do NOT get a row — the API returns null and the mobile section hides
// itself so noise stays low.
//
// payload jsonb shape (schemaVersion=1):
//   {
//     schemaVersion: 1,
//     revisions:      [{blockId, version, title, contributor, changedAt}],
//     newReferences:  [{id, title, sourceTier, url, sourceName}],
//     newEvents:      [{id, title, region, startsAt, thumbnailUrl}],
//     popularPosts:   [{id, snippet, roomSlug, likeCount, replyCount}],
//     spaceAccessPolicy: "PUBLIC" | "PLANNER_ONLY"
//   }
model TopicHubDigest {
  id          String   @id @default(uuid()) @db.Uuid
  topicHubId  String   @map("topic_hub_id") @db.Uuid
  periodStart DateTime @map("period_start") @db.Timestamptz(6)
  periodEnd   DateTime @map("period_end") @db.Timestamptz(6)
  payload     Json
  generatedAt DateTime @default(now()) @map("generated_at") @db.Timestamptz(6)

  hub TopicHub @relation(fields: [topicHubId], references: [id], onDelete: Cascade)

  @@unique([topicHubId, periodStart])
  @@index([topicHubId, periodEnd(sort: Desc)])
  @@map("topic_hub_digests")
}

// ---------------------------------------------------------------------------
// Rooms
// ---------------------------------------------------------------------------

model Room {
  id           String   @id @default(uuid()) @db.Uuid
  categoryId   String   @map("category_id") @db.Uuid
  ownerId      String?  @map("owner_id") @db.Uuid
  slug         String   @unique
  name         String
  description  String?
  rules        String?
  origin       String // OFFICIAL | USER
  roomType     String   @map("room_type") // DISCUSSION | EVENT_REACTION | REFERENCE | IDEA | RECRUITMENT | SOCIAL
  accessPolicy String   @default("PUBLIC") @map("access_policy")
  tags         Json     @default("[]")
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  category  Category     @relation(fields: [categoryId], references: [id])
  owner     User?        @relation(fields: [ownerId], references: [id])
  pins      RoomPin[]
  posts     Post[]
  followers RoomFollow[]
  roomRoles RoomRole[]

  @@index([categoryId])
  @@map("rooms")
}

// P6.12 delegated per-room moderation. A room owner can grant trusted
// members the room-scoped MODERATOR role without the heavyweight global
// MODERATOR. `revoked_at` soft-revokes (row kept for audit). UNIQUE
// (room_id, user_id) makes the grant idempotent — re-granting reuses
// the row.
model RoomRole {
  id        String    @id @default(uuid()) @db.Uuid
  roomId    String    @map("room_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      String // MODERATOR | MEMBER
  grantedBy String?   @map("granted_by") @db.Uuid
  grantedAt DateTime  @default(now()) @map("granted_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)

  room    Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user    User  @relation("RoomRoleMember", fields: [userId], references: [id], onDelete: Cascade)
  granter User? @relation("RoomRoleGranter", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@unique([roomId, userId])
  @@index([roomId, revokedAt])
  @@map("room_roles")
}

// target_type: EVENT_CARD | REFERENCE; target_id has no FK (resolved at read time).
model RoomPin {
  id         String   @id @default(uuid()) @db.Uuid
  roomId     String   @map("room_id") @db.Uuid
  targetType String   @map("target_type")
  targetId   String   @map("target_id") @db.Uuid
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@map("room_pins")
}

// ---------------------------------------------------------------------------
// Posts, replies, reactions
// ---------------------------------------------------------------------------

model Post {
  id                   String    @id @default(uuid()) @db.Uuid
  roomId               String    @map("room_id") @db.Uuid
  authorId             String    @map("author_id") @db.Uuid
  postType             String    @default("GENERAL") @map("post_type")
  body                 String
  visibility           String    @default("PUBLIC")
  status               String    @default("VISIBLE") // VISIBLE | HIDDEN | DELETED
  spoiler              Boolean   @default(false)
  replyCount           Int       @default(0) @map("reply_count")
  likeCount            Int       @default(0) @map("like_count")
  bookmarkCount        Int       @default(0) @map("bookmark_count")
  // P6.6 denormalised boost counter — keeps home-feed ordering O(1)
  // and lets the timeline serializer skip a per-row count() query.
  boostCount           Int       @default(0) @map("boost_count")
  recruitmentFields    Json?     @map("recruitment_fields")
  // P5.2 auto-moderation stamps. Non-null `autoModeratedAt` means the
  // post was hidden by a rule rather than a human moderator; the
  // admin queue surfaces these separately from manual reports.
  autoModeratedAt      DateTime? @map("auto_moderated_at") @db.Timestamptz(6)
  autoModerationReason String?   @map("auto_moderation_reason")
  // P6.7 reply gate. ANYONE | FOLLOWERS | MENTIONED_ONLY | DISABLED.
  // Enforced in ReplyService.create(); ANYONE keeps the legacy
  // open-to-anyone behaviour so existing posts don't need backfill.
  replyPolicy          String    @default("ANYONE") @map("reply_policy")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  room        Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author      User             @relation(fields: [authorId], references: [id])
  attachments PostAttachment[]
  replies     Reply[]
  recruitment RecruitmentPost?
  quote       PostQuote?       @relation("QuotingPost")
  quotedBy    PostQuote[]      @relation("QuotedPost")
  poll        Poll?
  boosts      PostBoost[]

  @@index([roomId, createdAt(sort: Desc)])
  @@map("posts")
}

// P6.6 boost — one row per (post, booster). Toggle off deletes the
// row + decrements `posts.boost_count` in the same transaction.
model PostBoost {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  boosterId String   @map("booster_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  post    Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  booster User @relation(fields: [boosterId], references: [id], onDelete: Cascade)

  @@unique([postId, boosterId], map: "post_boosts_post_booster_unique")
  @@index([boosterId, createdAt(sort: Desc)], map: "post_boosts_booster_idx")
  @@map("post_boosts")
}

// P6.5 polls. 1:1 sidecar on a post: the post body carries the
// preamble + author's opinion, the poll row carries the structured
// choices + vote counts. `expires_at` is enforced service-side; a
// poll past its expiry only accepts reads.
model Poll {
  id            String       @id @default(uuid()) @db.Uuid
  postId        String       @unique @map("post_id") @db.Uuid
  question      String
  expiresAt     DateTime?    @map("expires_at") @db.Timestamptz(6)
  allowMultiple Boolean      @default(false) @map("allow_multiple")
  status        String       @default("OPEN") // OPEN | CLOSED
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  post    Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]

  @@map("polls")
}

model PollOption {
  id        String @id @default(uuid()) @db.Uuid
  pollId    String @map("poll_id") @db.Uuid
  label     String
  sortOrder Int    @default(0) @map("sort_order")

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId, sortOrder], map: "poll_options_poll_id_idx")
  @@map("poll_options")
}

model PollVote {
  id        String   @id @default(uuid()) @db.Uuid
  pollId    String   @map("poll_id") @db.Uuid
  optionId  String   @map("option_id") @db.Uuid
  voterId   String   @map("voter_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  voter  User       @relation(fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([pollId, voterId, optionId], map: "poll_votes_poll_voter_option_unique")
  @@index([optionId], map: "poll_votes_option_idx")
  @@index([voterId], map: "poll_votes_voter_idx")
  @@map("poll_votes")
}

// P3.6: structured recruitment metadata. 1:1 with the parent Post
// (PK == post_id, so the row is created in the same transaction that
// creates a RECRUITMENT post). Status state machine:
//   OPEN → CLOSED      (planner manually closes)
//        → FILLED      (auto when ACCEPTED count == capacity)
//        → CANCELLED   (planner cancels before close)
// `deadline_at` is informational today; future cron will auto-CLOSE
// past-deadline rows.
model RecruitmentPost {
  postId     String    @id @map("post_id") @db.Uuid
  capacity   Int?
  status     String    @default("OPEN")
  deadlineAt DateTime? @map("deadline_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  post         Post                     @relation(fields: [postId], references: [id], onDelete: Cascade)
  applications RecruitmentApplication[]

  @@map("recruitment_posts")
}

// P3.6: per-applicant submission for a recruitment post. Unique on
// (post_id, applicant_id) so an applicant can't submit twice; the
// applicant can withdraw (status=WITHDRAWN) but a single row is the
// canonical history.
model RecruitmentApplication {
  id          String   @id @default(uuid()) @db.Uuid
  postId      String   @map("post_id") @db.Uuid
  applicantId String   @map("applicant_id") @db.Uuid
  message     String?
  status      String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | WITHDRAWN
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  recruitmentPost RecruitmentPost @relation(fields: [postId], references: [postId], onDelete: Cascade)
  applicant       User            @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([postId, applicantId])
  @@index([applicantId, createdAt(sort: Desc)])
  @@map("recruitment_applications")
}

model PostAttachment {
  id             String @id @default(uuid()) @db.Uuid
  postId         String @map("post_id") @db.Uuid
  attachmentType String @map("attachment_type") // EVENT_CARD | REFERENCE | IMAGE
  targetId       String @map("target_id") @db.Uuid
  sortOrder      Int    @default(0) @map("sort_order")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_attachments")
}

model MediaAsset {
  id         String   @id @default(uuid()) @db.Uuid
  ownerId    String   @map("owner_id") @db.Uuid
  kind       String // IMAGE (only supported kind in M10)
  filename   String
  mimeType   String   @map("mime_type")
  sizeBytes  Int      @map("size_bytes")
  path       String // legacy public URL — kept for backward compat
  // P1.4 additions. `cdn_url` is the canonical client-facing URL (CDN-fronted
  // when MEDIA_PUBLIC_BASE_URL points to one); `variants` holds derived
  // renditions like { thumb: "...", md: "..." }; `storage_key` is the
  // underlying object key (R2/S3) used by future reprocessing scripts.
  cdnUrl     String?  @map("cdn_url")
  variants   Json     @default("{}")
  width      Int?
  height     Int?
  storageKey String?  @map("storage_key")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  owner       User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  eventLives  EventLivePost[]

  @@index([ownerId, createdAt(sort: Desc)])
  @@map("media_assets")
}

model Reply {
  id            String   @id @default(uuid()) @db.Uuid
  postId        String   @map("post_id") @db.Uuid
  parentReplyId String?  @map("parent_reply_id") @db.Uuid
  authorId      String   @map("author_id") @db.Uuid
  body          String
  status        String   @default("VISIBLE")
  likeCount     Int      @default(0) @map("like_count")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  post         Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentReply  Reply?  @relation("ReplyChildren", fields: [parentReplyId], references: [id], onDelete: SetNull)
  childReplies Reply[] @relation("ReplyChildren")
  author       User    @relation(fields: [authorId], references: [id])

  @@index([postId, createdAt])
  @@map("replies")
}

// Milestone 1: only LIKE is used; target_type is POST or REPLY.
// UNIQUE constraint enforces toggle idempotency.
model Reaction {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  targetType   String   @map("target_type") // POST | REPLY
  targetId     String   @map("target_id") @db.Uuid
  // P6.4 reaction taxonomy:
  //   HEART | THUMBS_UP | FIRE | THINK | IDEA | LAUGH
  // Legacy LIKE rows were migrated to HEART in the P6.4 migration.
  reactionType String   @default("HEART") @map("reaction_type")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId], map: "reactions_user_target_unique")
  @@index([targetType, targetId])
  @@map("reactions")
}

// ---------------------------------------------------------------------------
// External integrations: event cards & references
// ---------------------------------------------------------------------------

model EventCard {
  id              String   @id @default(uuid()) @db.Uuid
  externalEventId String   @unique @map("external_event_id")
  title           String
  venueName       String   @map("venue_name")
  region          String
  startsAt        DateTime @map("starts_at") @db.Timestamptz(6)
  eventStatus     String   @map("event_status") // UPCOMING | COMPLETED
  thumbnailUrl    String?  @map("thumbnail_url")
  syncedAt        DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)

  topicHubLinks TopicHubEventLink[]
  rsvps         EventRsvp[]
  reminderSends EventReminderSend[]
  reviews       EventReview[]
  digests       EventCardDigest[]
  livePosts     EventLivePost[]

  @@map("event_cards")
}

// P6.8 event "현장 라이브" entries. Writable only while the event is
// in its IN_PROGRESS window (starts_at .. starts_at+4h) and only by
// users whose RSVP=ATTENDED. After 48h the cron sets archived_at —
// archived rows survive for audit but disappear from the read API.
model EventLivePost {
  id           String    @id @default(uuid()) @db.Uuid
  eventCardId  String    @map("event_card_id") @db.Uuid
  authorId     String    @map("author_id") @db.Uuid
  body         String
  imageMediaId String?   @map("image_media_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  archivedAt   DateTime? @map("archived_at") @db.Timestamptz(6)

  eventCard EventCard   @relation(fields: [eventCardId], references: [id], onDelete: Cascade)
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  image     MediaAsset? @relation(fields: [imageMediaId], references: [id], onDelete: SetNull)

  @@index([eventCardId, archivedAt, createdAt(sort: Desc)], map: "event_live_posts_card_idx")
  @@index([authorId, createdAt(sort: Desc)], map: "event_live_posts_author_idx")
  @@map("event_live_posts")
}

// Post-event "recap" rollup (P3.5). Generated by the P3.2 cron at D+1
// for COMPLETED events; one row per (event_card, periodStart). Pattern
// mirrors TopicHubDigest — empty events skip persistence.
//
// payload jsonb shape (schemaVersion=1):
//   {
//     schemaVersion: 1,
//     topPosts:    [{id, snippet, roomSlug, likeCount, replyCount}],
//     topReviews:  [{id, rating, snippet, userNickname, createdAt}],
//     reviewCount: number,
//     averageRating: number | null,
//     spaceAccessPolicy: "PUBLIC"
//   }
model EventCardDigest {
  id          String   @id @default(uuid()) @db.Uuid
  eventCardId String   @map("event_card_id") @db.Uuid
  periodStart DateTime @map("period_start") @db.Timestamptz(6)
  periodEnd   DateTime @map("period_end") @db.Timestamptz(6)
  payload     Json
  generatedAt DateTime @default(now()) @map("generated_at") @db.Timestamptz(6)

  eventCard EventCard @relation(fields: [eventCardId], references: [id], onDelete: Cascade)

  @@unique([eventCardId, periodStart])
  @@map("event_card_digests")
}

// Per-event-per-user-per-kind reminder dedup table (P3.2). UNIQUE on
// (event_card_id, user_id, reminder_kind) guarantees we never send the
// same kind twice even under concurrent cron ticks across instances.
model EventReminderSend {
  id           String   @id @default(uuid()) @db.Uuid
  eventCardId  String   @map("event_card_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  reminderKind String   @map("reminder_kind") // D1 | H1 | EVENT_DAY | REVIEW_PROMPT
  sentAt       DateTime @default(now()) @map("sent_at") @db.Timestamptz(6)

  eventCard EventCard @relation(fields: [eventCardId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventCardId, userId, reminderKind])
  @@index([eventCardId, reminderKind])
  @@map("event_reminder_sends")
}

// Per-user review per completed event (P3.3). One row per
// (event_card, user) so a single attendee can revise their review
// instead of stacking duplicates. Rating is 1..5; status carries
// through the standard VISIBLE / HIDDEN / DELETED moderation cycle
// (Report.targetType='EVENT_REVIEW').
model EventReview {
  id          String   @id @default(uuid()) @db.Uuid
  eventCardId String   @map("event_card_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  rating      Int
  body        String
  status      String   @default("VISIBLE")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  eventCard EventCard @relation(fields: [eventCardId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventCardId, userId])
  @@index([eventCardId, createdAt(sort: Desc)])
  @@map("event_reviews")
}

// Per-user RSVP per event card (P3.1). Status state machine:
//   INTERESTED → GOING → ATTENDED
// ATTENDED can only be set after the event has started (server-side
// gated; the client just calls POST with status=ATTENDED). DELETE
// removes the row entirely so users can withdraw without leaving a
// historical INTERESTED ghost behind.
model EventRsvp {
  id          String   @id @default(uuid()) @db.Uuid
  eventCardId String   @map("event_card_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  status      String // INTERESTED | GOING | ATTENDED
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  eventCard EventCard @relation(fields: [eventCardId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventCardId, userId])
  @@index([userId, updatedAt(sort: Desc)])
  @@index([eventCardId, status])
  @@map("event_rsvps")
}

// Prisma model name is `Reference` but table is `reference_items` —
// `references` is a Postgres reserved word (used in FK declarations).
model Reference {
  id           String   @id @default(uuid()) @db.Uuid
  createdBy    String   @map("created_by") @db.Uuid
  type         String // TV_SHOW | YOUTUBE | GAME_RULE | ARTICLE | IDEA | OTHER
  url          String
  title        String
  sourceName   String?  @map("source_name")
  thumbnailUrl String?  @map("thumbnail_url")
  summary      String?
  status       String   @default("VISIBLE")
  // P2.3: trust tier inferred from the URL host. OFFICIAL is reserved
  // for canonical sources (broadcaster, publisher); TRUSTED for known
  // creator platforms (YouTube, major news sites); COMMUNITY for forums
  // / blogs / KakaoStory; UNKNOWN when the host doesn't match any rule.
  // Mutable via admin retier endpoint; auto-set on create().
  sourceTier   String   @default("UNKNOWN") @map("source_tier")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  creator       User                    @relation(fields: [createdBy], references: [id])
  topicHubLinks TopicHubReferenceLink[]

  @@map("reference_items")
}

// Domain-to-tier mapping for P2.3 reference source quality.
// `domain_pattern` may be an exact host ("tving.com") or a wildcard
// like "*.youtube.com" (matches subdomains only). Evaluated in service
// code, not via SQL pattern operators, so we can normalise both sides
// the same way.
model ReferenceSourceRule {
  id            String   @id @default(uuid()) @db.Uuid
  domainPattern String   @unique @map("domain_pattern")
  tier          String // OFFICIAL | TRUSTED | COMMUNITY | UNKNOWN
  note          String?
  // Nullable so the migration's seed rules (no admin user attached) can
  // land cleanly; admin-created rules always carry the actor's id.
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  creator User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@map("reference_source_rules")
}

// ---------------------------------------------------------------------------
// Milestone 2: Knowledge contributions
// ---------------------------------------------------------------------------

// Proposed edits or additions to a TopicHub's knowledge blocks.
// Status state machine: PENDING → APPROVED | REJECTED | NEEDS_CHANGES | WITHDRAWN.
// On APPROVE, the service captures the pre-change block content in the
// snapshot_* columns and writes the proposed_* values to the target block
// (or creates a new block when target_block_id is null) — all in one Prisma
// transaction. The contribution row IS the audit trail for milestone 2.
//
// evidence_target_id has no FK (polymorphic on evidence_type), matching the
// same pattern as room_pins and post_attachments.
model KnowledgeContribution {
  id            String  @id @default(uuid()) @db.Uuid
  topicHubId    String  @map("topic_hub_id") @db.Uuid
  contributorId String  @map("contributor_id") @db.Uuid
  targetBlockId String? @map("target_block_id") @db.Uuid

  // Proposed (applied on APPROVE)
  proposedBlockType String @map("proposed_block_type")
  proposedTitle     String @map("proposed_title")
  proposedBody      String @map("proposed_body")

  // Optional single evidence attachment — EVENT_CARD | REFERENCE
  evidenceType     String? @map("evidence_type")
  evidenceTargetId String? @map("evidence_target_id") @db.Uuid

  // Curation state
  status      String    @default("PENDING")
  curatorNote String?   @map("curator_note")
  resolvedBy  String?   @map("resolved_by") @db.Uuid
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamptz(6)

  // Audit snapshot of overwritten content (captured on APPROVE for edits)
  snapshotBlockType String? @map("snapshot_block_type")
  snapshotTitle     String? @map("snapshot_title")
  snapshotBody      String? @map("snapshot_body")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  hub         TopicHub                 @relation(fields: [topicHubId], references: [id], onDelete: Cascade)
  contributor User                     @relation("Contributor", fields: [contributorId], references: [id])
  resolver    User?                    @relation("Resolver", fields: [resolvedBy], references: [id])
  targetBlock KnowledgeBlock?          @relation(fields: [targetBlockId], references: [id], onDelete: SetNull)
  revisions   KnowledgeBlockRevision[]

  @@index([topicHubId, status, createdAt(sort: Desc)])
  @@index([contributorId, createdAt(sort: Desc)])
  // P7.2: powers the validation-strength score's "approved
  // contributions for this block" count without a sequential scan.
  @@index([targetBlockId, status], map: "knowledge_contributions_target_status_idx")
  @@map("knowledge_contributions")
}

// ---------------------------------------------------------------------------
// Milestone 6: Follow / Save / Notification
// ---------------------------------------------------------------------------

model RoomFollow {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roomId    String   @map("room_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@map("room_follows")
}

// target_type: POST | REFERENCE | EVENT_CARD; target_id has no FK (resolved at read time).
model SavedItem {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  targetType   String   @map("target_type")
  targetId     String   @map("target_id") @db.Uuid
  // P4.4: optional folder assignment. NULL = uncategorised, which the
  // mobile renders under the "전체" tab.
  collectionId String?  @map("collection_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection SavedCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  @@unique([userId, targetType, targetId])
  @@index([userId, collectionId, createdAt(sort: Desc)])
  @@map("saved_items")
}

// P4.4: per-user named folder for organising saved items. Each user
// can have at most 20 collections; the service caps creates and
// surfaces a clean error otherwise.
model SavedCollection {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(50)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedItems SavedItem[]

  @@unique([userId, name])
  @@map("saved_collections")
}

// P4.2: quote-share. UNIQUE on quoting_post_id keeps the quote a 1:1
// from the quoting side; quoted_post is nullable so deleting the
// original doesn't take the quoter's reply with it (FK = SET NULL).
model PostQuote {
  id            String   @id @default(uuid()) @db.Uuid
  quotingPostId String   @unique @map("quoting_post_id") @db.Uuid
  quotedPostId  String?  @map("quoted_post_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  quotingPost Post  @relation("QuotingPost", fields: [quotingPostId], references: [id], onDelete: Cascade)
  quotedPost  Post? @relation("QuotedPost", fields: [quotedPostId], references: [id], onDelete: SetNull)

  @@index([quotedPostId, createdAt(sort: Desc)])
  @@map("post_quotes")
}

// P4.3: per-(user, recommended-user) follow recommendation cache.
// `score` is the Jaccard overlap on the categories the two users
// follow rooms in; recomputed nightly by the recommendations cron.
model FollowRecommendation {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  recommendedUserId String   @map("recommended_user_id") @db.Uuid
  score             Float
  reason            Json
  computedAt        DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)

  user            User @relation("FollowRecOwner", fields: [userId], references: [id], onDelete: Cascade)
  recommendedUser User @relation("FollowRecCandidate", fields: [recommendedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, recommendedUserId])
  @@index([userId, score(sort: Desc)])
  @@map("follow_recommendations")
}

// type: REPLY_ON_POST | NESTED_REPLY | NEW_POST_IN_FOLLOWED_ROOM |
//       RECRUITMENT_STATUS_CHANGED | CONTRIBUTION_RESOLVED
//       (future: EVENT_REMINDER | EVENT_UPDATED | REVIEW_PROMPT |
//        WEEKLY_DIGEST | POST_QUOTED)
// payload contains type-specific context + spaceAccessPolicy for access filtering.
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  payload   Json
  // P6.3: composite of (type + target) used by the grouping upsert.
  // Null means "no grouping — always create a new row" (mention,
  // digest, reminder). Service-side writers compute the key.
  groupKey  String?  @map("group_key")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  // P6.3: bumps when an actor is appended to the group so the read
  // surface can re-surface the row to top-of-inbox.
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([userId, groupKey, createdAt(sort: Desc)], map: "notifications_group_key_idx")
  @@map("notifications")
}

// P6.2 — user-level block. Bidirectional in effect: blocker no longer
// sees blocked's content; blocked cannot reply / quote / mention /
// follow the blocker. Read-time filter is centralised in
// VisibilityFilter so a missing call site is the source of any
// regression.
model UserBlock {
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId], map: "user_blocks_blocked_idx")
  @@map("user_blocks")
}

// P6.2 — user-level mute. One-way: muter hides muted's content from
// feeds / notifications without informing them. Mute is strictly
// softer than block — no write-side guard, just read-time filter.
model UserMute {
  muterId   String   @map("muter_id") @db.Uuid
  mutedId   String   @map("muted_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  muter User @relation("Muter", fields: [muterId], references: [id], onDelete: Cascade)
  muted User @relation("Muted", fields: [mutedId], references: [id], onDelete: Cascade)

  @@id([muterId, mutedId])
  @@map("user_mutes")
}

// P6.1 — single row per (sourceType, sourceId, mentionedUserId). Lets the
// "내 멘션 함" feed query by mentionedUserId + recency without re-parsing
// the post body, and lets PostService.delete() cascade-clean the rows.
//
// `actorId` is who wrote the mention (the post / reply author) so the
// notification copy can read "민서님이 회원님을 언급했어요" without a
// separate Post → author lookup.
model Mention {
  id              String   @id @default(uuid()) @db.Uuid
  sourceType      String   @map("source_type") // POST | REPLY
  sourceId        String   @map("source_id") @db.Uuid
  mentionedUserId String   @map("mentioned_user_id") @db.Uuid
  actorId         String   @map("actor_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  mentionedUser User @relation("MentionedUser", fields: [mentionedUserId], references: [id], onDelete: Cascade)
  actor         User @relation("MentionActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId, mentionedUserId], map: "mentions_source_user_unique")
  @@index([mentionedUserId, createdAt(sort: Desc)], map: "mentions_mentioned_user_idx")
  @@index([sourceType, sourceId], map: "mentions_source_idx")
  @@map("mentions")
}

// Device-bound push tokens (P1.2). Unique on (provider, token) so a fresh
// registration from the same device replaces the row; if the token was bound
// to a different user before, the previous binding is revoked (handled at the
// service layer). Index on (user_id, revoked_at) for active-fanout queries.
model DeviceToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  provider    String    @default("FCM") // FCM | APNS | WEB
  token       String
  platform    String // ANDROID | IOS | WEB
  appVersion  String?   @map("app_version")
  deviceModel String?   @map("device_model")
  locale      String?
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, token])
  @@index([userId, revokedAt])
  @@map("device_tokens")
}

// Per-user notification preferences (P1.2). Row is lazy-created the first time
// the controller reads it — absent row means "all defaults true". The master
// `pref_push_enabled` short-circuits PushDelivery; per-type bools gate
// individual notification rows.
model NotificationPreference {
  userId                       String    @id @map("user_id") @db.Uuid
  prefReplyOnPost              Boolean   @default(true) @map("pref_reply_on_post")
  prefNestedReply              Boolean   @default(true) @map("pref_nested_reply")
  prefNewPostInFollowedRoom    Boolean   @default(true) @map("pref_new_post_in_followed_room")
  prefRecruitmentStatusChanged Boolean   @default(true) @map("pref_recruitment_status_changed")
  prefContributionResolved     Boolean   @default(true) @map("pref_contribution_resolved")
  prefPushEnabled              Boolean   @default(true) @map("pref_push_enabled")
  prefEmailEnabled             Boolean   @default(true) @map("pref_email_enabled")
  // P4.6 weekly digest opt-in. Default false — users explicitly opt
  // in via the notification settings screen. `weeklyDigestLastSentAt`
  // is the cron's idempotency anchor (skip if within 6 days).
  weeklyDigestEnabled          Boolean   @default(false) @map("weekly_digest_enabled")
  weeklyDigestLastSentAt       DateTime? @map("weekly_digest_last_sent_at") @db.Timestamptz(6)
  updatedAt                    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt                    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}
