// PRISM Club schema — milestones 1 + 2.
// See docs/03_ARCHITECTURE_AND_DATA.md §5 for the full ERD this is a subset of.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

model User {
  id              String    @id @default(uuid()) @db.Uuid
  status          String    @default("ACTIVE")
  // Identity & credentials (M-P1.1). Existing seed personas are backfilled to
  // oauth_provider='DEV'; passwordless dev login keeps working when
  // ALLOW_DEV_LOGIN=1. Email uses citext (case-insensitive). Composite uniqueness
  // on (oauth_provider, oauth_id) is enforced via a partial index in the migration
  // — Prisma's @@unique cannot express WHERE clauses.
  email           String?   @unique @db.Citext
  phone           String?
  passwordHash    String?   @map("password_hash")
  oauthProvider   String?   @map("oauth_provider") // KAKAO | EMAIL | DEV
  oauthId         String?   @map("oauth_id")
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  profile                Profile?
  roles                  UserRole[]
  rooms                  Room[]
  posts                  Post[]
  replies                Reply[]
  reactions              Reaction[]
  references             Reference[]
  contributions          KnowledgeContribution[] @relation("Contributor")
  resolvedContributions  KnowledgeContribution[] @relation("Resolver")
  follows                RoomFollow[]
  savedItems             SavedItem[]
  notifications          Notification[]
  following              UserFollow[]            @relation("UserFollowing")
  followers              UserFollow[]            @relation("UserFollowers")
  reports                Report[]                @relation("ReportReporter")
  resolvedReports        Report[]                @relation("ReportResolver")
  moderationActions      ModerationAction[]
  mediaAssets            MediaAsset[]
  refreshTokens          RefreshToken[]
  deviceTokens           DeviceToken[]
  notificationPreference NotificationPreference?

  @@map("users")
}

// Opaque refresh tokens. Rotation lineage is tracked via family_id so a reused
// (revoked) child token can invalidate the entire family (replay defense).
// token_hash is SHA-256(rawToken); the raw token is never persisted.
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  familyId  String    @map("family_id") @db.Uuid
  userAgent String?   @map("user_agent")
  ip        String?
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([familyId])
  @@map("refresh_tokens")
}

// Short-lived OAuth state for Kakao authorization flow. Holds the CSRF state,
// PKCE code_verifier, and nonce. Rows expire 10 minutes after creation; the
// service filters by expires_at and a periodic cleanup is optional.
model OAuthState {
  state        String   @id
  codeVerifier String   @map("code_verifier")
  nonce        String
  redirectTo   String?  @map("redirect_to")
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([expiresAt])
  @@map("oauth_states")
}

model Report {
  id           String    @id @default(uuid()) @db.Uuid
  reporterId   String    @map("reporter_id") @db.Uuid
  targetType   String    @map("target_type")
  targetId     String    @map("target_id") @db.Uuid
  reason       String
  details      String?
  status       String    @default("OPEN")
  resolution   String?
  resolvedBy   String?   @map("resolved_by") @db.Uuid
  resolvedAt   DateTime? @map("resolved_at") @db.Timestamptz(6)
  resolverNote String?   @map("resolver_note")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  reporter User  @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver User? @relation("ReportResolver", fields: [resolvedBy], references: [id])

  @@index([status, createdAt(sort: Desc)])
  @@index([reporterId, createdAt(sort: Desc)])
  @@map("reports")
}

model ModerationAction {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String   @map("actor_id") @db.Uuid
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id") @db.Uuid
  reportId   String?  @map("report_id") @db.Uuid
  note       String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User @relation(fields: [actorId], references: [id])

  @@index([targetType, targetId, createdAt(sort: Desc)])
  @@map("moderation_actions")
}

model AnalyticsEvent {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  eventType String   @map("event_type")
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([eventType, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@map("analytics_events")
}

model UserFollow {
  id         String   @id @default(uuid()) @db.Uuid
  followerId String   @map("follower_id") @db.Uuid
  followedId String   @map("followed_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  follower User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  followed User @relation("UserFollowers", fields: [followedId], references: [id], onDelete: Cascade)

  @@unique([followerId, followedId])
  @@index([followedId])
  @@map("user_follows")
}

model Profile {
  userId    String   @id @map("user_id") @db.Uuid
  nickname  String   @unique
  avatarUrl String?  @map("avatar_url")
  bio       String?
  region    String?
  interests Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// Empty in milestone 1 seed; default MEMBER is implicit when no row.
// Future values: MEMBER, VERIFIED_PLANNER, MODERATOR, ADMIN, CURATOR.
model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String
  source    String?
  grantedAt DateTime @default(now()) @map("granted_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

// ---------------------------------------------------------------------------
// Community structure
// ---------------------------------------------------------------------------

model Space {
  id           String @id @default(uuid()) @db.Uuid
  slug         String @unique
  name         String
  audience     String @default("PARTICIPANT") // PARTICIPANT | PLANNER
  accessPolicy String @default("PUBLIC") @map("access_policy") // PUBLIC | PLANNER_ONLY (not enforced yet)
  status       String @default("ACTIVE")

  categories Category[]

  @@map("spaces")
}

model Category {
  id          String  @id @default(uuid()) @db.Uuid
  spaceId     String  @map("space_id") @db.Uuid
  slug        String  @unique
  name        String
  description String?
  sortOrder   Int     @default(0) @map("sort_order")
  status      String  @default("ACTIVE")

  space    Space     @relation(fields: [spaceId], references: [id])
  topicHub TopicHub?
  rooms    Room[]

  @@map("categories")
}

// ---------------------------------------------------------------------------
// Knowledge layer
// ---------------------------------------------------------------------------

model TopicHub {
  id         String   @id @default(uuid()) @db.Uuid
  categoryId String   @unique @map("category_id") @db.Uuid
  title      String
  summary    String
  status     String   @default("PUBLISHED")
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  category      Category                @relation(fields: [categoryId], references: [id])
  blocks        KnowledgeBlock[]
  signals       TopicSignal[]
  eventLinks    TopicHubEventLink[]
  refLinks      TopicHubReferenceLink[]
  contributions KnowledgeContribution[]

  @@map("topic_hubs")
}

// Block types: OVERVIEW | POPULAR_FORMAT | RECOMMENDED_PARTY_SIZE | MOOD_TIPS |
//              FAQ | CHECKLIST | WARNING
model KnowledgeBlock {
  id         String   @id @default(uuid()) @db.Uuid
  topicHubId String   @map("topic_hub_id") @db.Uuid
  blockType  String   @map("block_type")
  title      String
  body       String
  sortOrder  Int      @default(0) @map("sort_order")
  status     String   @default("PUBLISHED")
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  hub           TopicHub                @relation(fields: [topicHubId], references: [id], onDelete: Cascade)
  contributions KnowledgeContribution[]

  @@map("knowledge_blocks")
}

// Static in milestone 1 — populated by seed, not recomputed.
// Signal types: POPULAR_REFERENCE_COUNT | HOT_DEBATE_TITLE | VERIFIED_REVIEW_COUNT
model TopicSignal {
  id           String   @id @default(uuid()) @db.Uuid
  topicHubId   String   @map("topic_hub_id") @db.Uuid
  signalType   String   @map("signal_type")
  title        String
  payload      Json
  calculatedAt DateTime @default(now()) @map("calculated_at") @db.Timestamptz(6)

  hub TopicHub @relation(fields: [topicHubId], references: [id], onDelete: Cascade)

  @@map("topic_signals")
}

// Hub-level "related events" — independent of any single knowledge block.
model TopicHubEventLink {
  topicHubId  String @map("topic_hub_id") @db.Uuid
  eventCardId String @map("event_card_id") @db.Uuid
  sortOrder   Int    @default(0) @map("sort_order")

  hub       TopicHub  @relation(fields: [topicHubId], references: [id], onDelete: Cascade)
  eventCard EventCard @relation(fields: [eventCardId], references: [id], onDelete: Cascade)

  @@id([topicHubId, eventCardId])
  @@map("topic_hub_event_links")
}

// Hub-level "popular references" — independent of any single knowledge block.
model TopicHubReferenceLink {
  topicHubId  String @map("topic_hub_id") @db.Uuid
  referenceId String @map("reference_id") @db.Uuid
  sortOrder   Int    @default(0) @map("sort_order")

  hub       TopicHub  @relation(fields: [topicHubId], references: [id], onDelete: Cascade)
  reference Reference @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@id([topicHubId, referenceId])
  @@map("topic_hub_reference_links")
}

// ---------------------------------------------------------------------------
// Rooms
// ---------------------------------------------------------------------------

model Room {
  id           String   @id @default(uuid()) @db.Uuid
  categoryId   String   @map("category_id") @db.Uuid
  ownerId      String?  @map("owner_id") @db.Uuid
  slug         String   @unique
  name         String
  description  String?
  rules        String?
  origin       String // OFFICIAL | USER
  roomType     String   @map("room_type") // DISCUSSION | EVENT_REACTION | REFERENCE | IDEA | RECRUITMENT | SOCIAL
  accessPolicy String   @default("PUBLIC") @map("access_policy")
  tags         Json     @default("[]")
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  category  Category     @relation(fields: [categoryId], references: [id])
  owner     User?        @relation(fields: [ownerId], references: [id])
  pins      RoomPin[]
  posts     Post[]
  followers RoomFollow[]

  @@index([categoryId])
  @@map("rooms")
}

// target_type: EVENT_CARD | REFERENCE; target_id has no FK (resolved at read time).
model RoomPin {
  id         String   @id @default(uuid()) @db.Uuid
  roomId     String   @map("room_id") @db.Uuid
  targetType String   @map("target_type")
  targetId   String   @map("target_id") @db.Uuid
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@map("room_pins")
}

// ---------------------------------------------------------------------------
// Posts, replies, reactions
// ---------------------------------------------------------------------------

model Post {
  id                String   @id @default(uuid()) @db.Uuid
  roomId            String   @map("room_id") @db.Uuid
  authorId          String   @map("author_id") @db.Uuid
  postType          String   @default("GENERAL") @map("post_type")
  body              String
  visibility        String   @default("PUBLIC")
  status            String   @default("VISIBLE") // VISIBLE | HIDDEN | DELETED
  spoiler           Boolean  @default(false)
  replyCount        Int      @default(0) @map("reply_count")
  likeCount         Int      @default(0) @map("like_count")
  bookmarkCount     Int      @default(0) @map("bookmark_count")
  recruitmentFields Json?    @map("recruitment_fields")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  room        Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author      User             @relation(fields: [authorId], references: [id])
  attachments PostAttachment[]
  replies     Reply[]

  @@index([roomId, createdAt(sort: Desc)])
  @@map("posts")
}

model PostAttachment {
  id             String @id @default(uuid()) @db.Uuid
  postId         String @map("post_id") @db.Uuid
  attachmentType String @map("attachment_type") // EVENT_CARD | REFERENCE | IMAGE
  targetId       String @map("target_id") @db.Uuid
  sortOrder      Int    @default(0) @map("sort_order")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_attachments")
}

model MediaAsset {
  id        String @id @default(uuid()) @db.Uuid
  ownerId   String @map("owner_id") @db.Uuid
  kind      String // IMAGE (only supported kind in M10)
  filename  String
  mimeType  String @map("mime_type")
  sizeBytes Int    @map("size_bytes")
  path      String // legacy public URL — kept for backward compat
  // P1.4 additions. `cdn_url` is the canonical client-facing URL (CDN-fronted
  // when MEDIA_PUBLIC_BASE_URL points to one); `variants` holds derived
  // renditions like { thumb: "...", md: "..." }; `storage_key` is the
  // underlying object key (R2/S3) used by future reprocessing scripts.
  cdnUrl     String?  @map("cdn_url")
  variants   Json     @default("{}")
  width      Int?
  height     Int?
  storageKey String?  @map("storage_key")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, createdAt(sort: Desc)])
  @@map("media_assets")
}

model Reply {
  id            String   @id @default(uuid()) @db.Uuid
  postId        String   @map("post_id") @db.Uuid
  parentReplyId String?  @map("parent_reply_id") @db.Uuid
  authorId      String   @map("author_id") @db.Uuid
  body          String
  status        String   @default("VISIBLE")
  likeCount     Int      @default(0) @map("like_count")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  post         Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentReply  Reply?  @relation("ReplyChildren", fields: [parentReplyId], references: [id], onDelete: SetNull)
  childReplies Reply[] @relation("ReplyChildren")
  author       User    @relation(fields: [authorId], references: [id])

  @@index([postId, createdAt])
  @@map("replies")
}

// Milestone 1: only LIKE is used; target_type is POST or REPLY.
// UNIQUE constraint enforces toggle idempotency.
model Reaction {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  targetType   String   @map("target_type") // POST | REPLY
  targetId     String   @map("target_id") @db.Uuid
  reactionType String   @default("LIKE") @map("reaction_type")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId, reactionType])
  @@index([targetType, targetId])
  @@map("reactions")
}

// ---------------------------------------------------------------------------
// External integrations: event cards & references
// ---------------------------------------------------------------------------

model EventCard {
  id              String   @id @default(uuid()) @db.Uuid
  externalEventId String   @unique @map("external_event_id")
  title           String
  venueName       String   @map("venue_name")
  region          String
  startsAt        DateTime @map("starts_at") @db.Timestamptz(6)
  eventStatus     String   @map("event_status") // UPCOMING | COMPLETED
  thumbnailUrl    String?  @map("thumbnail_url")
  syncedAt        DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)

  topicHubLinks TopicHubEventLink[]

  @@map("event_cards")
}

// Prisma model name is `Reference` but table is `reference_items` —
// `references` is a Postgres reserved word (used in FK declarations).
model Reference {
  id           String   @id @default(uuid()) @db.Uuid
  createdBy    String   @map("created_by") @db.Uuid
  type         String // TV_SHOW | YOUTUBE | GAME_RULE | ARTICLE | IDEA | OTHER
  url          String
  title        String
  sourceName   String?  @map("source_name")
  thumbnailUrl String?  @map("thumbnail_url")
  summary      String?
  status       String   @default("VISIBLE")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  creator       User                    @relation(fields: [createdBy], references: [id])
  topicHubLinks TopicHubReferenceLink[]

  @@map("reference_items")
}

// ---------------------------------------------------------------------------
// Milestone 2: Knowledge contributions
// ---------------------------------------------------------------------------

// Proposed edits or additions to a TopicHub's knowledge blocks.
// Status state machine: PENDING → APPROVED | REJECTED | NEEDS_CHANGES | WITHDRAWN.
// On APPROVE, the service captures the pre-change block content in the
// snapshot_* columns and writes the proposed_* values to the target block
// (or creates a new block when target_block_id is null) — all in one Prisma
// transaction. The contribution row IS the audit trail for milestone 2.
//
// evidence_target_id has no FK (polymorphic on evidence_type), matching the
// same pattern as room_pins and post_attachments.
model KnowledgeContribution {
  id            String  @id @default(uuid()) @db.Uuid
  topicHubId    String  @map("topic_hub_id") @db.Uuid
  contributorId String  @map("contributor_id") @db.Uuid
  targetBlockId String? @map("target_block_id") @db.Uuid

  // Proposed (applied on APPROVE)
  proposedBlockType String @map("proposed_block_type")
  proposedTitle     String @map("proposed_title")
  proposedBody      String @map("proposed_body")

  // Optional single evidence attachment — EVENT_CARD | REFERENCE
  evidenceType     String? @map("evidence_type")
  evidenceTargetId String? @map("evidence_target_id") @db.Uuid

  // Curation state
  status      String    @default("PENDING")
  curatorNote String?   @map("curator_note")
  resolvedBy  String?   @map("resolved_by") @db.Uuid
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamptz(6)

  // Audit snapshot of overwritten content (captured on APPROVE for edits)
  snapshotBlockType String? @map("snapshot_block_type")
  snapshotTitle     String? @map("snapshot_title")
  snapshotBody      String? @map("snapshot_body")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  hub         TopicHub        @relation(fields: [topicHubId], references: [id], onDelete: Cascade)
  contributor User            @relation("Contributor", fields: [contributorId], references: [id])
  resolver    User?           @relation("Resolver", fields: [resolvedBy], references: [id])
  targetBlock KnowledgeBlock? @relation(fields: [targetBlockId], references: [id], onDelete: SetNull)

  @@index([topicHubId, status, createdAt(sort: Desc)])
  @@index([contributorId, createdAt(sort: Desc)])
  @@map("knowledge_contributions")
}

// ---------------------------------------------------------------------------
// Milestone 6: Follow / Save / Notification
// ---------------------------------------------------------------------------

model RoomFollow {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roomId    String   @map("room_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@map("room_follows")
}

// target_type: POST | REFERENCE | EVENT_CARD; target_id has no FK (resolved at read time).
model SavedItem {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  targetType String   @map("target_type")
  targetId   String   @map("target_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("saved_items")
}

// type: REPLY_ON_POST | NESTED_REPLY | NEW_POST_IN_FOLLOWED_ROOM |
//       RECRUITMENT_STATUS_CHANGED | CONTRIBUTION_RESOLVED
//       (future: EVENT_REMINDER | EVENT_UPDATED | REVIEW_PROMPT |
//        WEEKLY_DIGEST | POST_QUOTED)
// payload contains type-specific context + spaceAccessPolicy for access filtering.
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  payload   Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

// Device-bound push tokens (P1.2). Unique on (provider, token) so a fresh
// registration from the same device replaces the row; if the token was bound
// to a different user before, the previous binding is revoked (handled at the
// service layer). Index on (user_id, revoked_at) for active-fanout queries.
model DeviceToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  provider    String    @default("FCM") // FCM | APNS | WEB
  token       String
  platform    String // ANDROID | IOS | WEB
  appVersion  String?   @map("app_version")
  deviceModel String?   @map("device_model")
  locale      String?
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, token])
  @@index([userId, revokedAt])
  @@map("device_tokens")
}

// Per-user notification preferences (P1.2). Row is lazy-created the first time
// the controller reads it — absent row means "all defaults true". The master
// `pref_push_enabled` short-circuits PushDelivery; per-type bools gate
// individual notification rows.
model NotificationPreference {
  userId                       String   @id @map("user_id") @db.Uuid
  prefReplyOnPost              Boolean  @default(true) @map("pref_reply_on_post")
  prefNestedReply              Boolean  @default(true) @map("pref_nested_reply")
  prefNewPostInFollowedRoom    Boolean  @default(true) @map("pref_new_post_in_followed_room")
  prefRecruitmentStatusChanged Boolean  @default(true) @map("pref_recruitment_status_changed")
  prefContributionResolved     Boolean  @default(true) @map("pref_contribution_resolved")
  prefPushEnabled              Boolean  @default(true) @map("pref_push_enabled")
  prefEmailEnabled             Boolean  @default(true) @map("pref_email_enabled")
  updatedAt                    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
