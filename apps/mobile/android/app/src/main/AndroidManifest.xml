<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
      INTERNET — required for every API call the app makes (Dio → REST,
      media uploads, /v1/auth/login, etc.). Declared in the main manifest
      (rather than only the debug/profile overlays auto-generated by
      `flutter create`) so the release build also carries it. Without this,
      a release APK would fail every network request with
      java.net.UnknownHostException.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!--
      POST_NOTIFICATIONS — runtime permission required on Android 13+
      (API 33) for any app that wants to show notification posts.
      firebase_messaging respects this gate; without it, the OS silently
      drops every push at the system level even though FCM reports
      success-from-server. We prompt at first launch via permission_handler
      (see lib/core/push/fcm_bootstrap.dart).
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
        android:label="@string/app_name"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!--
          Default channel firebase_messaging registers system-side. The
          channel itself is also created from Dart for backwards-compat
          (see fcm_bootstrap.dart); this meta-data lets FCM-direct
          payloads (without a Dart-side handler) post into a sensible
          channel instead of falling back to "Miscellaneous".
        -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="prism_default" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!--
          url_launcher (used by ReferenceTile to open external URLs) needs
          to be able to discover an activity that handles http/https on
          Android 11+ (API 30+), which restricts package visibility. Without
          these queries, `launchUrl(...)` returns false and the user sees
          the "URL을 열지 못했어요" snackbar even though the OS has a
          browser installed.
        -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="http"/>
        </intent>
    </queries>
</manifest>
