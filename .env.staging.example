# ============================================================================
# PRISM Club — staging environment template.
#
# Copy this file's contents into your staging secret store (NOT into a
# committed `.env`), then fill in the placeholder values with the real
# staging credentials.
#
# Companion doc: docs/STAGING_SETUP.md
# Production runbook: docs/BETA_LAUNCH_RUNBOOK.md
#
# Placeholder convention: `<...>` means "replace with the staging value
# before deploy". Leave the empty values empty until §8 / §9 of
# STAGING_SETUP.md says to flip them on.
# ============================================================================

# --- Database (REQUIRED, secret) ---
# Dedicated staging DB + user. Do NOT reuse the production credentials.
DATABASE_URL=postgresql://prism_staging:<staging-password>@<host>:5432/prism_club_staging?schema=public

# --- API process ---
# Port the platform binds (8080 on Cloud Run, 3000 on most platforms).
API_PORT=8080
# Yes, production — even on staging. Loosens guards otherwise.
NODE_ENV=production

# --- Build metadata (M21) ---
# Set by the deploy pipeline. SAFE to expose via /v1/health/version.
APP_VERSION=<semver-or-build-id>
GIT_SHA=<short-or-full-sha>
BUILD_TIME=<iso8601-timestamp>
RELEASE_CHANNEL=staging

# --- M13: auth ---
# Fresh JWT secret. Generate with: openssl rand -hex 32
# MUST be distinct from production. NEVER commit.
JWT_SECRET=<staging-jwt-secret>
# Staging-only convenience: lets scripts/smoke.sh use the legacy
# X-User-Id header. Production MUST leave this unset.
ALLOW_X_USER_ID=1

# --- M14: deployment / runtime ---
# Comma-separated origin allowlist. Add both staging hosts. No `*`.
CORS_ORIGINS=https://app.staging.<your-domain>,https://admin.staging.<your-domain>

# Where the API writes uploads when MEDIA_STORAGE_MODE=local. Container
# image defaults this to /app/uploads; override only if you mount the
# volume somewhere else.
UPLOADS_DIR=/app/uploads

# --- M15: PRISM EVENT / CONTENIDO integration ---
# First boot: keep mock so staging works without upstream creds.
# Flip to `prism` per STAGING_SETUP.md §8 once the real creds are ready.
EVENTS_CLIENT_MODE=mock
# Set both of the following only when flipping to prism mode.
PRISM_EVENTS_API_BASE_URL=
PRISM_EVENTS_API_KEY=
PRISM_EVENTS_TIMEOUT_MS=4000

# --- M16: media storage ---
# First boot: local is acceptable for staging smoke. Switch to `s3`
# before opening staging to external testers (STAGING_SETUP.md §9).
MEDIA_STORAGE_MODE=local

# Required when MEDIA_STORAGE_MODE=s3:
MEDIA_PUBLIC_BASE_URL=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: override endpoint for R2 / MinIO. Leave empty for AWS.
S3_ENDPOINT=
# Recommended: partition staging objects so they're easy to identify.
S3_OBJECT_PREFIX=staging-uploads
# `1` for MinIO-style hosts; leave empty for AWS / R2.
S3_FORCE_PATH_STYLE=

# --- M17: notification delivery ---
# Beta default. The email / push boundaries are stubs — do not flip
# until a real provider is wired (NEXT_BACKLOG §2).
NOTIFICATION_DELIVERY_MODE=noop
EMAIL_PROVIDER=
EMAIL_FROM_ADDRESS=
EMAIL_API_KEY=
EMAIL_REGION=
PUSH_PROVIDER=
PUSH_SERVICE_ACCOUNT=
